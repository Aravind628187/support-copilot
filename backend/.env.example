# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Comma-separated list of origins allowed to call this API with credentials
CORS_ORIGIN=http://localhost:5173

# ── Database ────────────────────────────────────────────────────────────────
# Postgres connection string. Works with Neon, Supabase, Railway, or local Postgres.
DATABASE_URL="postgresql://neondb_owner:npg_ZT2HmPNS9JVG@ep-super-tree-atb1x26i-pooler.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# ── Auth ────────────────────────────────────────────────────────────────────
# Long, random strings in production — never reuse these examples.
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Rate limiting ───────────────────────────────────────────────────────────
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MIN=15
