# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
# Comma-separated list of origins allowed to call this API with credentials
CORS_ORIGIN=http://localhost:5173
# Used as the post-login redirect destination. Defaults to the first CORS origin.
FRONTEND_URL=http://localhost:5173

# ── Database ────────────────────────────────────────────────────────────────
# Postgres connection string. Works with Render, Neon, Supabase, Railway, or local Postgres.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# ── Auth ────────────────────────────────────────────────────────────────────
# Long, random strings in production — never reuse these examples.
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Rate limiting ───────────────────────────────────────────────────────────
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MIN=15

# ── Google OAuth ────────────────────────────────────────────────────────────
# Create a Web application OAuth client in Google Cloud and register the exact
# callback URL below as an Authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
